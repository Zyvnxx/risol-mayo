{
    "version": 2,
    "builds": [
        {
            "src": "index.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "includeFiles": [
                    "index.html",
                    "style.css",
                    "app.js"
                ]
            }
        }
    ],
    "rewrites": [
        { "source": "/(.*)", "destination": "/index.py" }
    ]
}
