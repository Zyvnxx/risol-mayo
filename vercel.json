{
    "version": 2,
    "builds": [
        {
            "src": "index.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "includeFiles": "**/*"
            }
        }
    ],
    "routes": [
        { "src": "/(.*)", "dest": "/index.py" }
    ]
}
